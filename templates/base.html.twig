<!DOCTYPE html>
<html lang="en" data-theme="corporate">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Digital Portal{% endblock %}</title>
  {{ vite_entry_link_tags('app') }}
</head>
<body class="min-h-screen bg-base-200">

  {# ── Navbar ── #}
  <div class="navbar bg-base-100 shadow-md px-6 sticky top-0 z-50">

    {# Mobile hamburger #}
    <div class="navbar-start">
      <label for="sidebar-drawer" class="btn btn-ghost lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
             viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </label>
      <a href="/" class="text-xl font-bold text-primary ml-2">
        🏛 Digital Portal
      </a>
    </div>

    <div class="navbar-end gap-3">

      {# Theme switcher #}
      <div class="dropdown dropdown-end">
        <label tabindex="0" class="btn btn-ghost btn-sm gap-1">
          🎨 <span class="hidden sm:inline">Theme</span>
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/>
          </svg>
        </label>
        <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-40 z-50">
          <li><a onclick="setTheme('corporate')">🏢 Corporate</a></li>
          <li><a onclick="setTheme('light')">☀️ Light</a></li>
          <li><a onclick="setTheme('dark')">🌙 Dark</a></li>
          <li><a onclick="setTheme('forest')">🌲 Forest</a></li>
        </ul>
      </div>

      {# User dropdown #}
      <div class="dropdown dropdown-end">
        <label tabindex="0" class="btn btn-ghost btn-circle avatar placeholder">
          <div class="bg-primary text-primary-content rounded-full w-9">
            <span class="text-sm font-bold">
              {{ app.user ? app.user.getUserIdentifier()|slice(0,1)|upper : '?' }}
            </span>
          </div>
        </label>
        <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-48 z-50 mt-2">
          <li class="menu-title">
            <span>{{ app.user ? app.user.getUserIdentifier() : 'Guest' }}</span>
          </li>
          <li><a href="{{ path('profile_show') }}">👤 Profile</a></li>
          <li><a href="{{ path('profile_settings') }}">⚙️ Settings</a></li>
          <li><hr class="my-1"></li>
          <li><a href="/auth/logout" class="text-error">🚪 Logout</a></li>
        </ul>
      </div>

    </div>
  </div>

  {# ── Drawer layout (mobile sidebar) ── #}
  <div class="drawer lg:drawer-open">
    <input id="sidebar-drawer" type="checkbox" class="drawer-toggle"/>

    <div class="drawer-content flex flex-col">
      <main class="flex-1 p-6">
        {% block body %}{% endblock %}
      </main>
    </div>

    {# ── Sidebar ── #}
    <div class="drawer-side z-40">
      <label for="sidebar-drawer" class="drawer-overlay"></label>
      <aside class="w-64 min-h-screen bg-base-100 shadow-inner flex flex-col">

        <div class="p-4 border-b border-base-200">
          <p class="text-xs text-base-content/50 uppercase tracking-widest">Navigation</p>
        </div>

        <ul class="menu menu-vertical p-3 flex-1 gap-1">

  <li>
    <a href="{{ path('app_home') }}"
       class="{{ app.request.pathInfo == '/' ? 'active' : '' }}">
      🏠 Dashboard
    </a>
  </li>



  {% set applets = get_nav_applets() %}
    {% if applets is not empty %}
    <li class="menu-title mt-3"><span>Applets</span></li>
    {% for applet in applets %}
      <li>
        <a href="{{ path('applet_show', {slug: applet.slug}) }}"
           class="{{ app.request.pathInfo starts with '/applet/' ~ applet.slug ? 'active' : '' }}">
          {{ applet.icon }} {{ applet.name }}
        </a>
      </li>
    {% endfor %}
  {% endif %}

  {% if is_granted('ROLE_ADMIN') %}
    <li class="menu-title mt-3"><span>Admin</span></li>
    <li>
      <a href="{{ path('admin_dashboard') }}"
         class="{{ app.request.pathInfo starts with '/admin' ? 'active' : '' }}">
        🛠 Control Panel
      </a>
    </li>
    <li><a href="{{ path('admin_users') }}">👤 Users</a></li>
  {% endif %}

</ul>

        <div class="p-4 border-t border-base-200 text-xs text-base-content/40">
          Portal v1.0 · Symfony 7.4 
        </div>

      </aside>
    </div>
  </div>

  {{ vite_entry_script_tags('app') }}

<script>
  function setTheme(theme) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('portal-theme', theme);
  }
  // Priority: DB saved theme > localStorage > default
  const dbTheme  = '{{ app.user and app.user.theme ? app.user.theme : '' }}';
  const saved    = dbTheme || localStorage.getItem('portal-theme') || 'corporate';
  document.documentElement.setAttribute('data-theme', saved);
</script>
</body>
</html>