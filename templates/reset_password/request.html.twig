{% extends 'base.html.twig' %}
{% block title %}Réinitialisation — Digital Portal{% endblock %}

{% block body %}
<div class="max-w-md mx-auto mt-10">
    <div class="card bg-base-100 shadow-xl border-2 border-base-300">
        <div class="card-body">
            <h2 class="card-title text-2xl font-black">Réinitialisation</h2>
            <p class="text-sm opacity-60">Entrez votre email pour recevoir un lien de récupération.</p>

            {{ form_start(requestForm, {attr: {class: 'mt-4 flex flex-col gap-4'}}) }}
                <div class="form-control">
                    {{ form_label(requestForm.email, 'Votre adresse email', {label_attr: {class: 'label label-text font-bold'}}) }}
                    {{ form_widget(requestForm.email, {attr: {
                        class: 'input input-bordered border-2 w-full focus:border-primary',
                        placeholder: 'exemple@domaine.com'
                    }}) }}
                </div>
                
                <button type="submit" class="btn btn-primary mt-2">Envoyer l'email →</button>
            {{ form_end(requestForm) }}
        </div>
    </div>
</div>
{% endblock %}