{% extends 'base.html.twig' %}
{% block title %}Nouveau mot de passe — Digital Portal{% endblock %}

{% block body %}
<div class="max-w-md mx-auto mt-10">
    <div class="card bg-base-100 shadow-xl border-2 border-base-300">
        <div class="card-body">
            <h2 class="card-title text-2xl font-black">Nouveau mot de passe</h2>
            
            {{ form_start(resetForm, {attr: {class: 'mt-4 flex flex-col gap-4'}}) }}
                <div class="form-control">
                    {{ form_label(resetForm.plainPassword.first, 'Mot de passe', {label_attr: {class: 'label label-text font-bold'}}) }}
                    {{ form_widget(resetForm.plainPassword.first, {attr: {class: 'input input-bordered border-2 focus:border-primary'}}) }}
                </div>
                <div class="form-control">
                    {{ form_label(resetForm.plainPassword.second, 'Confirmez le mot de passe', {label_attr: {class: 'label label-text font-bold'}}) }}
                    {{ form_widget(resetForm.plainPassword.second, {attr: {class: 'input input-bordered border-2 focus:border-primary'}}) }}
                </div>
                
                <button type="submit" class="btn btn-primary mt-4">Changer le mot de passe</button>
            {{ form_end(resetForm) }}
        </div>
    </div>
</div>
{% endblock %}