{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[60vh]">
    <div class="card bg-base-100 shadow-xl w-full max-w-sm border-2 border-base-300">
        <div class="card-body">
            <h2 class="card-title text-2xl font-black italic">Réinitialisation</h2>
            <p class="text-sm opacity-60">Entrez votre email pour recevoir un lien magique.</p>
            
            <form method="POST" class="mt-4 flex flex-col gap-4">
                <div class="form-control">
                    <label class="label"><span class="label-text font-bold">Email</span></label>
                    <input type="email" name="email" required class="input input-bordered border-2 focus:border-primary" placeholder="votre@email.com">
                </div>
                
                <button type="submit" class="btn btn-primary w-full">Envoyer le lien →</button>
            </form>

            <div class="divider"></div>
            <a href="{{ path('auth_login') }}" class="btn btn-ghost btn-sm">Retour à la connexion</a>
        </div>
    </div>
</div>
{% endblock %}