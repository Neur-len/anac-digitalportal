<!DOCTYPE html>
<html lang="fr" data-theme="corporate">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Modifier le mot de passe — Portail Numérique{% endblock %}</title>
  {{ vite_entry_link_tags('app') }}
</head>
<body class="min-h-screen bg-base-200 flex items-center justify-center p-4">

  <div class="card bg-base-100 shadow-xl w-full max-w-sm border-2 border-base-300">
    <div class="card-body">

      <div class="text-center mb-4">
        <div class="text-4xl mb-2">🔐</div>
        <h1 class="text-xl font-bold">Modifier votre mot de passe</h1>
        <p class="text-base-content/50 text-sm">
          Vous devez définir un nouveau mot de passe avant de continuer.
        </p>
      </div>

      {% if error %}
        <div class="alert alert-error text-sm mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-4 w-4" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>{{ error }}</span>
        </div>
      {% endif %}

      <form method="POST" class="flex flex-col gap-3">
        <div class="form-control">
          <label class="label">
            <span class="label-text font-bold">Nouveau mot de passe</span>
          </label>
          <input type="password" name="password" required autofocus
                 minlength="8" 
                 class="input input-bordered border-2 w-full focus:border-primary shadow-sm"
                 placeholder="••••••••">
        </div>

        <div class="form-control">
          <label class="label">
            <span class="label-text font-bold">Confirmer le mot de passe</span>
          </label>
          <input type="password" name="confirm" required
                 minlength="8" 
                 class="input input-bordered border-2 w-full focus:border-primary shadow-sm"
                 placeholder="••••••••">
        </div>

        <button type="submit" class="btn btn-primary w-full mt-4 shadow-md">
          Enregistrer et continuer →
        </button>
      </form>

    </div>
  </div>

  {{ vite_entry_script_tags('app') }}
</body>
</html>