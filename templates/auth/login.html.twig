<!DOCTYPE html>
<html lang="fr" data-theme="corporate">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion — Portail Digital</title>
  {{ vite_entry_link_tags('app') }}

  <style>
    /* On applique l'image au body avec un overlay sombre pour la lisibilité */
    body {
      background: 
        linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), 
        url('{{ asset("images/fly.jpg") }}') no-repeat center center fixed;
      background-size: cover;
    }
  </style>
</head>
<body class="min-h-screen flex flex-col lg:flex-row">

    {# ✅ Mobile Greeting (only small screens) #}
    <div class="text-center text-white m-6 lg:hidden drop-shadow-[0_4px_6px_rgba(0,0,0,0.7)]">
        <h2 class="text-4xl font-bold tracking-wide drop-shadow-[0_4px_6px_rgba(0,0,0,0.7)]">Bienvenue</h2>
        <p class="text-sm font-bold opacity-80 drop-shadow-[0_4px_6px_rgba(0,0,0,0.7)]">Accédez au portail digital sécurisé de l'ANAC BENIN</p>
      </div>

  {# ── GAUCHE : Formulaire (Transparent pour voir l'image) ── #}
  <div class="flex-1 flex items-center justify-center p-6 lg:p-12 bg-image">

    <div class="card bg-base-100 shadow-xl w-full max-w-sm rounded-2xl">
      <div class="card-body">

        <div class="text-center mb-4">
          <div class="mb-2 flex justify-center">
            <div class="p-3 rounded-full bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M5.121 17.804A9 9 0 1118.88 17.8M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
          </div>
          <h1 class="text-xl font-bold">Connexion</h1>
          <p class="text-base-content/50 text-sm">
            {{ step == 'otp' ? 'Enter your verification code' : "Connectez-vous aux applications de l'ANAC" }}
          </p>
        </div>

        {% if error %}
          <div class="alert alert-error text-sm mb-2">{{ error }}</div>
        {% endif %}

        {% if step == 'credentials' %}

          <form method="POST" class="flex flex-col gap-3">
            <input type="hidden" name="step" value="credentials">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('auth') }}">

            <div class="form-control">
              <label class="label"><span class="label-text">Email</span></label>
              <input type="email" name="email" required autofocus
                     class="input input-bordered w-full shadow-sm rounded-xl"
                     placeholder="you@example.com">
            </div>

            <div class="form-control">
              <label class="label"><span class="label-text">Mot de Passe</span></label>
              <input type="password" name="password" required
                     class="input input-bordered w-full shadow-sm rounded-xl"
                     placeholder="••••••••">
            </div>
            <div class="form-control">
              <div class="flex justify-between items-center">
                <a href="{{ path('app_forgot_password_request') }}" class="text-xs link link-primary no-underline hover:underline">
                  Mot de passe Oublié ?
                </a>
              </div>
            </div>

            <button type="submit" class="btn btn-primary w-full mt-2 shadow-sm rounded-xl">
              Continue →
            </button>
          </form>

        {% else %}

          <form method="POST" action="{{ path('auth_login') }}" class="flex flex-col gap-3">
            <input type="hidden" name="step" value="otp">
            <input type="hidden" name="email" value="{{ email }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('auth') }}">

            <div class="alert alert-info text-sm">
              Un code a 6 chiffres vous a été envoyé sur <strong>{{ email }}</strong>
            </div>

            <div class="form-control">
              <label class="label"><span class="label-text">Code de Vérification</span></label>
              <input type="text" name="otp" required autofocus
                     maxlength="6" pattern="[0-9]{6}"
                     class="input input-bordered w-full text-center text-2xl tracking-widest"
                     placeholder="000000">
            </div>

            <button type="submit" class="btn btn-primary w-full mt-2">
              Verification →
            </button>

            <a href="{{ path('auth_login') }}" class="btn btn-ghost btn-sm w-full"
               onclick="fetch('', {method:'POST', body: new URLSearchParams({step: 'cancel'})})">
              ← Utiliser un autre compte
            </a>
          </form>

        {% endif %}

      </div>
    </div>
  </div>

  {# ── DROITE : Logos (Effet Glassmorphism) ── #}
  {# On utilise backdrop-blur et une opacité faible pour un effet haut de gamme #}
  <div class="hidden lg:flex lg:flex-1 relative items-center justify-center p-12 overflow-hidden backdrop-blur-sm bg-white/5 border-l border-white/10">
    
    <div class="relative z-10 flex flex-col gap-10 items-center w-full max-w-xs">
      
      {# ✅ Welcome Message #}
      <div class="text-center text-white drop-shadow-[0_4px_6px_rgba(0,0,0,0.7)]">
        <h2 class="text-4xl font-bold tracking-wide drop-shadow-[0_4px_6px_rgba(0,0,0,0.7)]">Bienvenue</h2>
        <p class="text-md font-bold opacity-80 drop-shadow-[0_4px_6px_rgba(0,0,0,0.7)]">Accédez au portail digital sécurisé de l'ANAC BENIN</p>
      </div>

      {# Premier Logo #}
      <div class="w-full aspect-[3/2] bg-white/90 rounded-3xl shadow-2xl flex items-center justify-center p-8 transition-transform duration-500 hover:scale-105">
        <img src="{{ asset('images/anac_logo.png') }}" alt="Anac Logo" class="w-full h-full object-contain">
      </div>

      {# Second Logo #}
      <div class="w-full aspect-[3/2] bg-white/90 rounded-3xl shadow-2xl flex items-center justify-center p-8 transition-transform duration-500 hover:scale-105">
        <img src="{{ asset('images/mcv_logo.png') }}" alt="Ministere Logo" class="w-full h-full object-contain">
      </div>

    </div>
  </div>

  {{ vite_entry_script_tags('app') }}
</body>
</html>