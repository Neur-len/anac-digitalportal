{% extends 'base.html.twig' %}
{% block title %}Applets — Admin{% endblock %}

{% block body %}
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold">Applets</h1>
      <p class="text-base-content/60 text-sm mt-1">{{ applets|length }} registered</p>
    </div>
    <a href="{{ path('admin_applet_new') }}" class="btn btn-primary btn-sm">＋ New Applet</a>
  </div>

  {% for flash in app.flashes('success') %}
    <div class="alert alert-success mb-4">{{ flash }}</div>
  {% endfor %}

  {% if applets is empty %}
    <div class="hero min-h-[40vh]">
      <div class="hero-content text-center text-base-content/40">
        <div>
          <div class="text-5xl mb-3">📭</div>
          <p>No applets registered yet.</p>
          <a href="{{ path('admin_applet_new') }}" class="btn btn-primary btn-sm mt-4">Register one</a>
        </div>
      </div>
    </div>
  {% else %}
    <div class="overflow-x-auto bg-base-100 rounded-box shadow">
      <table class="table">
        <thead>
          <tr>
            <th>Applet</th>
            <th>Category</th>
            <th>URL</th>
            <th>Roles</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for applet in applets %}
            <tr>
              <td>
                <div class="font-medium">{{ applet.icon }} {{ applet.name }}</div>
                <div class="text-xs text-base-content/50">{{ applet.description }}</div>
              </td>
              <td><div class="badge badge-ghost">{{ applet.category ?? '—' }}</div></td>
              <td class="text-xs font-mono text-base-content/60">{{ applet.url }}</td>
              <td>
                {% for role in applet.allowedRoles %}
                  <div class="badge badge-outline badge-sm">{{ role }}</div>
                {% endfor %}
              </td>
              <td>
                <div class="badge {{ applet.status == 'online' ? 'badge-success' : (applet.status == 'maintenance' ? 'badge-warning' : 'badge-error') }}">
                  {{ applet.status }}
                </div>
              </td>
              <td class="flex gap-2">
                <a href="{{ path('admin_applet_edit', {id: applet.id}) }}" class="btn btn-ghost btn-xs">✏️</a>
                <form method="POST" action="{{ path('admin_applet_delete', {id: applet.id}) }}">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete-applet-' ~ applet.id) }}">
                  <button class="btn btn-ghost btn-xs text-error"
                          onclick="return confirm('Delete {{ applet.name }}?')">🗑️</button>
                </form>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
{% endblock %}